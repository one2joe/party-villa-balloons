---
import siteSettings from '../data/site-settings.json';

const links = siteSettings?.socialLinks || [];
const facebook = links.find((l: string) => l.includes('facebook.com')) || '';
const instagram = links.find((l: string) => l.includes('instagram.com')) || '';
const tiktok = links.find((l: string) => l.includes('tiktok.com')) || '';
const line = links.find((l: string) => l.includes('line.me')) || '';
const logoUrl = siteSettings?.logo || '/images/logo.png';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <img src={logoUrl} alt="Party Villa Balloons" height="45" class="footer-logo" />
        <p>บริการจัดลูกโป่งเชียงใหม่ รับจัดลูกโป่งทุกโอกาส ครบวงจร ตั้งแต่จัดสถานที่ จนถึงบริการส่งถึงที่</p>
      </div>

      <div class="footer-col">
        <h4>ช่องทางติดต่อ</h4>
        <ul>
          <li>โทร: <a href="tel:0930518591">093-0518591</a></li>
          <li>LINE: <a href={line}>@partyvilla</a></li>
          <li>Facebook: <a href={facebook} target="_blank">Party Villa Balloons</a></li>
          <li>TikTok: <a href={tiktok} target="_blank">@partyvillaballoon</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>บริการของเรา</h4>
        <ul>
          <li><a href="/\u0E1A\u0E23\u0E34\u0E01\u0E32\u0E23/">จัดลูกโป่งมาตรฐาน</a></li>
          <li><a href="/\u0E1A\u0E23\u0E34\u0E01\u0E32\u0E23/">SnapBloom ลูกโป่งเอฟเฟกต์</a></li>
          <li><a href="/\u0E1A\u0E23\u0E34\u0E01\u0E32\u0E23/">บริการส่งและติดตั้ง</a></li>
          <li><a href="/portfolio">ดูผลงานทั้งหมด</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>พื้นที่ให้บริการ</h4>
        <p>เชียงใหม่และจังหวัดใกล้เคียง</p>
        <div class="footer-social">
          <a href={facebook} target="_blank" class="social-btn" aria-label="Facebook">FB</a>
          <a href={instagram} target="_blank" class="social-btn" aria-label="Instagram">IG</a>
          <a href={tiktok} target="_blank" class="social-btn" aria-label="TikTok">TT</a>
          <a href={line} target="_blank" class="social-btn" aria-label="LINE">LINE</a>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} Party Villa Balloons. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark, #333);
    color: rgba(255, 255, 255, 0.8);
    padding-top: 60px;
    font-size: 0.95rem;
    line-height: 1.8;
  }
  .footer-logo {
    margin-bottom: 16px;
    filter: brightness(0) invert(1);
    height: 45px;
    width: auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 40px;
  }
  .footer-col h4 {
    color: #fff;
    font-size: 1.1rem;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .footer-col p {
    color: rgba(255, 255, 255, 0.7);
  }
  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col ul a {
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.2s;
  }
  .footer-col ul a:hover {
    color: var(--primary, #fb3c8b);
  }
  .footer-social {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }
  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    transition: background 0.2s, color 0.2s;
  }
  .social-btn:hover {
    background: var(--primary, #fb3c8b);
    color: #fff;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding: 20px 0;
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
