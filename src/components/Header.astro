---
import siteSettings from '../data/site-settings.json';

const navItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'เกี่ยวกับเรา', href: '/เกี่ยวกับเรา/' },
  { label: 'บริการ', href: '/บริการ/' },
  { label: 'ผลงาน', href: '/ผลงาน/' },
  { label: 'บทความ', href: '/บทความ/' },
  { label: 'ติดต่อเรา', href: '/ติดต่อเรา/' },
];

const { currentPath = '/' } = Astro.props;
const links = siteSettings?.socialLinks || [];

const socialIcons = [
  { name: 'Facebook', url: links.find((l: string) => l.includes('facebook.com')) || '', icon: 'facebook' },
  { name: 'Instagram', url: links.find((l: string) => l.includes('instagram.com')) || '', icon: 'instagram' },
  { name: 'TikTok', url: links.find((l: string) => l.includes('tiktok.com')) || '', icon: 'tiktok' },
].filter(s => s.url);
const headerLine = links.find((l: string) => l.includes('line.me')) || '';

const logoUrl = siteSettings?.logo || '/images/logo.png';
const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href));

const FB_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`;
const IG_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`;
const TT_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`;
const LINE_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1C5.9 1 1 5.4 1 10.9c0 3.1 1.6 5.9 4.2 7.8-.2.8-.7 2.8-.8 3.2-.1.5.2.6.5.4 2.5-1.7 4.1-2.8 4.5-3.1.9.2 1.8.3 2.7.3 6.1 0 11-4.4 11-9.9C23 5.4 18.1 1 12 1z"/></svg>`;
const iconMap: Record<string, string> = { facebook: FB_SVG, instagram: IG_SVG, tiktok: TT_SVG, line: LINE_SVG };
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link" aria-label="หน้าแรก">
      <img src={logoUrl} alt="Party Villa" class="logo-img" width="180" height="45" loading="eager" />
    </a>

    <nav class="desktop-nav" aria-label="เมนหลัก">
      {navItems.map(item => (
        <a href={item.href} class:list={{ 'nav-link': true, active: isActive(item.href) }}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <div class="social-links social-icons">
        {socialIcons.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class={`social-icon button ${s.icon}`} aria-label={s.name}>
            <i class={`icon-${s.icon}`} set:html={iconMap[s.icon]} />
          </a>
        ))}
      </div>
      {headerLine && (
        <a href={headerLine} target="_blank" rel="noopener noreferrer" class="social-icon line" aria-label="LINE" set:html={LINE_SVG} />
      )}

      <button class="hamburger" aria-label="เปิดเมนู" data-hamburger>
        <i class="icon-menu"></i>
      </button>
      <a href="#" class="button" aria-label="เมนู"><i class="icon-menu"></i></a>
      <a class="button" aria-label="ค้นหา"><i class="icon-search"></i></a>
    </div>
  </div>

  <div class="mobile-overlay" data-mobile-overlay>
    <div class="mobile-drawer">
      <span class="mobile-close" aria-label="ปิดเมนู" data-mobile-close>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </span>

      <nav class="mobile-nav" aria-label="เมนหลัก">
        {navItems.map(item => (
          <a href={item.href} class:list={{ 'mobile-nav-link': true, active: isActive(item.href) }} data-mobile-nav>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="mobile-social">
        {socialIcons.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class={`social-icon ${s.icon}`} aria-label={s.name} set:html={iconMap[s.icon]} />
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height, 80px);
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #eee;
    z-index: 1000;
  }
  .header-inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo-link {
    flex-shrink: 0;
    line-height: 0;
  }
  .logo-img {
    height: 45px;
    width: auto;
  }
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-link {
    padding: 8px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-color, #333);
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--primary, #fb3c8b);
  }
  .nav-link.active {
    color: var(--primary, #fb3c8b);
    font-weight: 700;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .social-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #666;
    transition: color 0.2s, background 0.2s;
  }
  .social-icon:hover {
    color: var(--primary, #fb3c8b);
    background: rgba(251, 60, 139, 0.08);
  }
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-color, #333);
    padding: 6px;
    border-radius: 6px;
    transition: background 0.2s;
  }
  .hamburger:hover {
    background: var(--bg-light, #f5f5f5);
  }
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-overlay.open {
    opacity: 1;
    pointer-events: all;
  }
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -300px;
    width: 280px;
    max-width: 85vw;
    height: 100%;
    background: #fff;
    z-index: 1001;
    padding: 80px 24px 24px;
    transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
  }
  .mobile-overlay.open .mobile-drawer {
    right: 0;
  }
  .mobile-close {
    position: absolute;
    top: 16px;
    right: 16px;
    color: #333;
    cursor: pointer;
    padding: 8px;
    line-height: 0;
  }
  .mobile-close:hover {
    background: var(--bg-light, #f5f5f5);
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mobile-nav-link {
    padding: 14px 16px;
    font-size: 1.05rem;
    color: var(--text-color, #333);
    border-radius: var(--radius, 8px);
    transition: background 0.2s, color 0.2s;
  }
  .mobile-nav-link:hover {
    background: var(--bg-light, #f5f5f5);
    color: var(--primary, #fb3c8b);
  }
  .mobile-nav-link.active {
    color: var(--primary, #fb3c8b);
    font-weight: 700;
    background: rgba(251, 60, 139, 0.06);
  }
  .mobile-social {
    display: flex;
    gap: 8px;
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid var(--border-color, #eee);
  }
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }
    .social-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('[data-hamburger]');
  const overlay = document.querySelector('[data-mobile-overlay]');
  const closeBtn = document.querySelector('[data-mobile-close]');
  const navLinks = document.querySelectorAll('[data-mobile-nav]');

  if (hamburger && overlay) {
    hamburger.addEventListener('click', () => {
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
    closeBtn?.addEventListener('click', () => {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      });
    });
  }
</script>

