---
import siteSettings from '../data/site-settings.json';

const navItems = [
  { label: '\u0E2B\u0E19\u0E49\u0E32\u0E41\u0E23\u0E01', href: '/' },
  { label: '\u0E40\u0E01\u0E35\u0E48\u0E22\u0E27\u0E01\u0E31\u0E1A\u0E40\u0E23\u0E32', href: '/\u0E40\u0E01\u0E35\u0E48\u0E22\u0E27\u0E01\u0E31\u0E1A\u0E40\u0E23\u0E32/' },
  { label: '\u0E1A\u0E23\u0E34\u0E01\u0E32\u0E23', href: '/\u0E1A\u0E23\u0E34\u0E01\u0E32\u0E23/' },
  { label: '\u0E1C\u0E25\u0E07\u0E32\u0E19', href: '/\u0E1C\u0E25\u0E07\u0E32\u0E19/' },
  { label: '\u0E1A\u0E17\u0E04\u0E27\u0E32\u0E21', href: '/\u0E1A\u0E17\u0E04\u0E27\u0E32\u0E21/' },
  { label: '\u0E15\u0E34\u0E14\u0E15\u0E48\u0E2D\u0E40\u0E23\u0E32', href: '/\u0E15\u0E34\u0E14\u0E15\u0E48\u0E2D\u0E40\u0E23\u0E32/' },
];

const { currentPath = '/' } = Astro.props;
const links = siteSettings?.socialLinks || [];

const socialIcons = [
  { name: 'Facebook', url: links.find((l: string) => l.includes('facebook.com')) || '', icon: 'facebook' },
  { name: 'TikTok', url: links.find((l: string) => l.includes('tiktok.com')) || '', icon: 'tiktok' },
  { name: 'LINE', url: links.find((l: string) => l.includes('line.me')) || '', icon: 'line' },
].filter(s => s.url);

const logoUrl = siteSettings?.logo || '/images/logo.png';
const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href));

const FB_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`;
const TT_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`;
const LINE_SVG = `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1C5.9 1 1 5.4 1 10.9c0 3.1 1.6 5.9 4.2 7.8-.2.8-.7 2.8-.8 3.2-.1.5.2.6.5.4 2.5-1.7 4.1-2.8 4.5-3.1.9.2 1.8.3 2.7.3 6.1 0 11-4.4 11-9.9C23 5.4 18.1 1 12 1z"/></svg>`;
const iconMap: Record<string, string> = { facebook: FB_SVG, tiktok: TT_SVG, line: LINE_SVG };
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link" aria-label="\u0E2B\u0E19\u0E49\u0E32\u0E41\u0E23\u0E01">
      <img src={logoUrl} alt="Party Villa Balloons" class="logo-img" width="180" height="45" loading="eager" />
    </a>

    <nav class="desktop-nav" aria-label="\u0E40\u0E21\u0E19\u0E2B\u0E25\u0E31\u0E01">
      {navItems.map(item => (
        <a href={item.href} class:list={{ 'nav-link': true, active: isActive(item.href) }}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <div class="social-links">
        {socialIcons.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label={s.name} set:html={iconMap[s.icon]} />
        ))}
      </div>

      <button class="hamburger" aria-label="\u0E40\u0E1B\u0E34\u0E14\u0E40\u0E21\u0E19\u0E39" data-hamburger>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-overlay" data-mobile-overlay>
    <div class="mobile-drawer">
      <button class="mobile-close" aria-label="\u0E1B\u0E34\u0E14\u0E40\u0E21\u0E19\u0E39" data-mobile-close>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>

      <nav class="mobile-nav" aria-label="\u0E40\u0E21\u0E19\u0E2B\u0E25\u0E31\u0E01">
        {navItems.map(item => (
          <a href={item.href} class:list={{ 'mobile-nav-link': true, active: isActive(item.href) }} data-mobile-nav>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="mobile-social">
        {socialIcons.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label={s.name} set:html={iconMap[s.icon]} />
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height, 80px);
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #eee;
    z-index: 1000;
  }
  .header-inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo-link {
    flex-shrink: 0;
    line-height: 0;
  }
  .logo-img {
    height: 45px;
    width: auto;
  }
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-link {
    padding: 8px 14px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-color, #333);
    transition: color 0.2s;
    position: relative;
    white-space: nowrap;
    border-radius: var(--radius, 8px);
  }
  .nav-link:hover {
    color: var(--primary, #fb3c8b);
    background: rgba(251, 60, 139, 0.06);
  }
  .nav-link.active {
    color: var(--primary, #fb3c8b);
    font-weight: 700;
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 3px;
    background: var(--primary, #fb3c8b);
    border-radius: 2px;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .social-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #666;
    transition: color 0.2s, background 0.2s;
  }
  .social-icon:hover {
    color: var(--primary, #fb3c8b);
    background: rgba(251, 60, 139, 0.08);
  }
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-color, #333);
    padding: 6px;
    border-radius: 6px;
    transition: background 0.2s;
  }
  .hamburger:hover {
    background: var(--bg-light, #f5f5f5);
  }
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-overlay.open {
    opacity: 1;
    pointer-events: all;
  }
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -300px;
    width: 280px;
    max-width: 85vw;
    height: 100%;
    background: #fff;
    z-index: 1001;
    padding: 80px 24px 24px;
    transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
  }
  .mobile-overlay.open .mobile-drawer {
    right: 0;
  }
  .mobile-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-color, #333);
    padding: 6px;
    border-radius: 6px;
    transition: background 0.2s;
  }
  .mobile-close:hover {
    background: var(--bg-light, #f5f5f5);
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mobile-nav-link {
    padding: 14px 16px;
    font-size: 1.05rem;
    color: var(--text-color, #333);
    border-radius: var(--radius, 8px);
    transition: background 0.2s, color 0.2s;
  }
  .mobile-nav-link:hover {
    background: var(--bg-light, #f5f5f5);
    color: var(--primary, #fb3c8b);
  }
  .mobile-nav-link.active {
    color: var(--primary, #fb3c8b);
    font-weight: 700;
    background: rgba(251, 60, 139, 0.06);
  }
  .mobile-social {
    display: flex;
    gap: 8px;
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid var(--border-color, #eee);
  }
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }
    .social-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('[data-hamburger]');
  const overlay = document.querySelector('[data-mobile-overlay]');
  const closeBtn = document.querySelector('[data-mobile-close]');
  const navLinks = document.querySelectorAll('[data-mobile-nav]');

  if (hamburger && overlay) {
    hamburger.addEventListener('click', () => {
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
    closeBtn?.addEventListener('click', () => {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      });
    });
  }
</script>
