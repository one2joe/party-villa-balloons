---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import posts from '../../data/blog-posts.json';

export function getStaticPaths() {
  return posts.filter(p => p.slug).map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const recentPosts = posts.filter(p => p.slug !== post.slug).slice(0, 3);
---

<Layout title={`${post.title} - Party Villa`}>
  <Header currentPath={Astro.url.pathname} />

  <section class="section-padding">
    <div class="container" style="max-width:900px;">
      <article>
        <time style="color:#999;">{post.date}</time>
        <h1 style="margin:12px 0 24px; font-size:1.8rem;">{post.title}</h1>
        {post.image && <img src={post.image} alt={post.imageAlt || post.title} style="width:100%; border-radius:var(--radius); margin-bottom:30px;" />}

        <div style="line-height:2;">
          {post.bodyParts?.map(part => {
            if (part.type === 'heading') return `<h2 style="margin:24px 0 12px; color:var(--primary);">${part.text}</h2>`;
            if (part.type === 'paragraph') return `<p style="margin-bottom:16px;">${part.text}</p>`;
            if (part.type === 'list' && part.items) {
              return `<ul style="margin-bottom:16px; padding-left:20px;">${part.items.map(i => `<li style="list-style:disc;">${i}</li>`).join('')}</ul>`;
            }
            return '';
          }).join('')}
        </div>
      </article>

      <hr style="margin:40px 0; border:none; border-top:1px solid var(--border-color);" />

      <div>
        <h3 style="margin-bottom:12px;">บทความอื่นๆ</h3>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          {recentPosts.map(p => (
            <a href={`/บทความ/${p.slug}`} class="related-post-tag">{p.title}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .related-post-tag {
    padding: 8px 16px;
    background: var(--bg-light);
    border-radius: 20px;
    font-size: 0.9rem;
    transition: background 0.3s, color 0.3s;
  }
  .related-post-tag:hover {
    background: var(--primary);
    color: #fff;
  }
</style>
