---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import faq from '../data/faq.json';
import homeContent from '../data/home-content.json';
import aboutContent from '../data/about-content.json';
import services from '../data/services.json';

const tiktokEmbeds = homeContent.tiktokEmbeds || [];
const heroBg = homeContent.hero?.background || '/images/hero-bg.jpg';
const heroTitle = homeContent.hero?.title || 'Party Villa Balloons';
const heroSubtitle = homeContent.hero?.subtitle || 'บริการจัดลูกโป่งครบวงจรในเชียงใหม่';
const ownerTagline = homeContent.hero?.ownerTagline || '';
const heroCtaText = homeContent.hero?.ctaText || 'ดูผลงานของเรา';
const heroCtaUrl = homeContent.hero?.ctaUrl || '/portfolio';
const pinkyImage = homeContent.pinky?.image || '/images/pinky-car.jpg';
const pinkyDesc = homeContent.pinky?.description || 'รถ Pinky สุดคิ้วท์บริการถึงที่ พร้อมลูกโป่งสวยๆ ส่งตรงถึงงานคุณ';
const strengthsContent = aboutContent.sections?.[2]?.content || '';
const siteUrl = 'https://party-villa-balloons.pages.dev';
const shareText = 'Party%20Villa%20Balloons';
const ownerName = homeContent.hero?.ownerName || 'อุ้ม';
const welcomeEmoji = '🎈✨';
const welcomeText = 'ยินดีต้อนรับสู่ "ปาร์ตี้ วิลล่า บอลลูน" ' + '🎉🎊';
const welcomeDesc = 'คุณกำลังมองหาการตกแต่งงานปาร์ตี้ที่สวยงามและน่าประทับใจใช่ไหม? Party Villa Balloons คือคำตอบสำหรับทุกงานของคุณ';
const ownerDesc = 'อุ้ม ดูแลงานเองทุกขั้นตอน โดยมุ่งมั่นให้แบรนด์เป็นที่หนึ่งในใจลูกค้าเมื่อพูดถึง ลูกโป่งเชียงใหม่';
---

<Layout title="Party Villa Balloons | รับจัดลูกโป่งเชียงใหม่ ครบวงจร">
  <Header currentPath={Astro.url.pathname} />

  <!-- Hero -->
  <section class="hero-parallax" style={`background-image: url('${heroBg}');`}>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      {ownerTagline && <p class="owner-name">{ownerTagline}</p>}
      <h1>{heroTitle}</h1>
      <p>{heroSubtitle}</p>
      <div class="hero-actions">
        <a href={heroCtaUrl} target="_blank" class="btn btn-outline">{heroCtaText}</a>
      </div>
    </div>
  </section>

  <!-- Welcome -->
  <section class="section-padding" style="text-align:center;">
    <div class="container" style="max-width:900px;">
      <p style="font-size:1.2rem; font-weight:600; color:var(--primary);">{welcomeEmoji} {welcomeText}</p>
      <p style="font-size:1.1rem; margin-top:16px; line-height:1.8;">{welcomeDesc}</p>
      <p style="margin-top:12px; line-height:1.8; color:#666;">{ownerDesc}</p>
    </div>
  </section>

  <!-- Services -->
  <section class="section-padding" style="background:var(--bg-light);">
    <div class="container">
      <h2 class="section-title">บริการของเรา</h2>
      <p class="section-subtitle">บริการจัดลูกโป่งครบวงจร จาก Party Villa</p>
      <div class="service-cards">
        {services.map(s => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h3 class="service-title">{s.title}</h3>
            <p class="service-desc">{s.description}</p>
            <ul class="service-features">
              {s.features.map(f => (
                <li>{f}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:30px;">
        <a href="/บริการ/" class="btn">ดูบริการเพิ่มเติม</a>
      </div>
    </div>
  </section>

  <!-- Pinky + Strengths -->
  <section class="section-padding">
    <div class="container" style="max-width:900px;">
      <h2 class="section-title">จุดเด่นของเรา</h2>
      <p class="section-subtitle">เรามีบริการจัดส่งลูกโป่งให้ถึงที่ โดยมีรถ "Pinky" เจ้าแรกและเจ้าเดียวในเชียงใหม่</p>
      <div style="max-width:600px; margin:0 auto;">
        <img src={pinkyImage} alt="Pinky car" style="border-radius:var(--radius); box-shadow:var(--shadow-md); width:100%;" />
      </div>
      {pinkyDesc && <p style="margin-top:24px; max-width:700px; margin-inline:auto; line-height:1.8;">{pinkyDesc}</p>}
      <div class="strengths-content" set:html={strengthsContent}></div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding" style="background:var(--bg-light);">
    <div class="container" style="max-width:800px;">
      <h2 class="section-title">คำถามที่พบบ่อย (FAQ)</h2>
      <p class="section-subtitle">คำถามที่ลูกค้ามักสอบถาม</p>
      <div class="faq-list">
        {faq.map((item, i) => (
          <div class="faq-item">
            <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
              <span>{item.question}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p set:html={item.answer}></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TikTok -->
  <section class="section-padding" style="text-align:center;">
    <div class="container">
      <h2 class="section-title">ติดตามเราบน TikTok</h2>
      <p class="section-subtitle">@partyvillaballoon</p>
      <div class="tiktok-embed-grid">
        {tiktokEmbeds.map(t => (
          <blockquote class="tiktok-embed" cite={t.url} data-video-id={t.videoId}>
            <section></section>
          </blockquote>
        ))}
      </div>
      <div style="text-align:center; margin-top:30px;">
        <a href="https://www.tiktok.com/@partyvillaballoon" target="_blank" class="btn">ดูเพิ่มเติมบน TikTok</a>
      </div>
    </div>
    <script async src="https://www.tiktok.com/embed.js"></script>
  </section>

  <!-- CTA -->
  <section class="section-padding" style="background:var(--primary); color:#fff; text-align:center;">
    <div class="container">
      <h2 style="font-size:1.8rem; margin-bottom:16px;">มีคำถาม หรืออยากปรึกษาออกแบบลูกโป่ง</h2>
      <p style="font-size:1.1rem; margin-bottom:24px;">ส่งรูปงาน หรือแนวคิดมาได้เลย เราจะช่วยออกแบบให้สวยที่สุด อุ้มตอบเองทุกข้อความ</p>
      <a href="https://line.me/R/ti/p/@partyvilla" target="_blank" class="btn" style="background:#fff; color:var(--primary);">พูดคุยกับเรา</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
  }
  .owner-name {
    font-size: 1.1rem;
    margin-bottom: 8px;
    display: inline-block;
    background: rgba(251, 60, 139, 0.15);
    color: var(--primary);
    padding: 6px 18px;
    border-radius: 50px;
    font-weight: 700;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  .service-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 30px;
  }
  .service-card {
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 30px;
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }
  .service-title {
    font-size: 1.15rem;
    color: var(--primary);
    margin-bottom: 10px;
  }
  .service-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .service-features {
    text-align: left;
    list-style: disc;
    padding-left: 18px;
    font-size: 0.85rem;
    line-height: 1.8;
    color: #555;
  }
  .strengths-content {
    line-height: 2;
    font-size: 1.05rem;
    margin-top: 30px;
  }
  .strengths-content :global(ol),
  .strengths-content :global(ul) {
    padding-left: 24px;
    margin: 12px 0;
  }
  .strengths-content :global(li) {
    margin-bottom: 8px;
  }
  .strengths-content :global(strong) {
    color: var(--primary);
  }
  .tiktok-embed-grid {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .tiktok-embed-grid .tiktok-embed {
    min-width: 325px;
    max-width: 400px;
    flex: 1;
  }
  .faq-list {
    margin-top: 24px;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    padding: 16px 20px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    color: var(--text-color);
  }
  .faq-icon {
    font-size: 1.4rem;
    color: var(--primary);
    transition: transform 0.3s;
    flex-shrink: 0;
    margin-left: 12px;
  }
  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    padding: 0 20px;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
    padding: 0 20px 16px;
  }
  .faq-answer p {
    line-height: 1.8;
    color: #555;
  }
  @media (max-width: 768px) {
    .service-cards {
      grid-template-columns: 1fr;
    }
    .tiktok-embed-grid {
      flex-direction: column;
      align-items: center;
    }
    .tiktok-embed-grid .tiktok-embed {
      min-width: unset;
      width: 100%;
      max-width: 400px;
    }
  }
</style>
