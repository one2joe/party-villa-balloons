---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import faq from '../data/faq.json';
import homeContent from '../data/home-content.json';
import aboutContent from '../data/about-content.json';
const homeServices = homeContent.homeServices || [];
const heroBg = homeContent.hero?.background || '/images/hero-bg.jpg';
const heroTitle = homeContent.hero?.title || 'Party Villa Balloons';
const heroSubtitle = homeContent.hero?.subtitle || 'เติมความสุขทุกงานเทศกาลด้วยลูกโป่ง พร้อมส่งตรงถึงงานด้วยรถ Pinky สุดน่ารัก';
const ownerTagline = homeContent.hero?.ownerTagline || '';
const heroCtaText = homeContent.hero?.ctaText || 'ดูผลงานของเรา';
const heroCtaUrl = homeContent.hero?.ctaUrl || '/portfolio';
const pinkyImage = homeContent.pinky?.image || '/images/pinky-car.jpg';
const pinkyDesc = homeContent.pinky?.description || 'รถ Pinky สุดคิ้วท์บริการถึงที่ พร้อมลูกโป่งสวยๆ ส่งตรงถึงงานคุณ';
const strengthsContent = aboutContent.sections?.[2]?.content || '';
const siteUrl = 'https://party-villa-balloons.pages.dev';
const shareText = 'Party%20Villa%20Balloons';
const ownerName = homeContent.hero?.ownerName || 'อุ้ม';
const welcomeDesc = '🎈✨ ยินดีต้อนรับสู่ "ปาร์ตี้ วิลล่า บอลลูน" 🎉🎊 คุณกำลังมองหาการตกแต่งงานปาร์ตี้ที่สวยงามและน่าประทับใจอยู่ใช่ไหม? มาหาเราที่ "ปาร์ตี้ วิลล่า บอลลูน" ร้านลูกโป่งเชียงใหม่ เรามีลูกโป่งหลากหลายแบบ สีสันสดใส และการตกแต่งที่สร้างสรรค์ที่จะทำให้ทุกงานของคุณเป็นที่น่าจดจำ!🌈 มีบริการครอบคลุมจังหวัด เชียงใหม่ และลำพูน';
const ownerDesc = 'อุ้ม ดูแลงานเองทุกขั้นตอน โดยมุ่งมั่นให้แบรนด์เป็นที่หนึ่งในใจลูกค้าเมื่อพูดถึง ลูกโป่งเชียงใหม่';
---

<Layout title="Party Villa Balloons | รับจัดลูกโป่งเชียงใหม่ ครบวงจร">
  <Header currentPath={Astro.url.pathname} />

  <!-- Hero -->
  <section class="hero-parallax" style={`background-image: url('${heroBg}');`}>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      {ownerTagline && <p class="owner-name">{ownerTagline}</p>}
      <h1>{heroTitle}</h1>
      <p>{heroSubtitle}</p>
      <div class="hero-actions">
        <a href={heroCtaUrl} target="_blank" class="btn btn-outline">{heroCtaText}</a>
      </div>
    </div>
  </section>

  <!-- Welcome -->
  <section class="section-padding" style="text-align:center;">
    <div class="container" style="max-width:900px;">
      <p style="font-size:1.1rem; font-weight:500; color:var(--text-color); margin-bottom:12px;">{homeContent.intro}</p>
      <p style="font-size:1rem; line-height:1.8;">{welcomeDesc}</p>
      <p style="margin-top:12px; line-height:1.8; color:#666;">{ownerDesc}</p>
    </div>
  </section>

  <!-- H1 Section: "ลูกโป่งเชียงใหม่" -->
  <section class="section-padding" style="text-align:center; padding:40px 0;">
    <div class="container">
      <h1 style="font-size:2.2rem; color:#000; margin:0;">&ldquo;ลูกโป่งเชียงใหม่&rdquo;</h1>
    </div>
  </section>

  <!-- Services -->
  <section class="section-padding">
    <div class="container">
      <h2 class="section-title">บริการของเรา</h2>
      <p class="section-subtitle">Party Villa Balloons Chiangmai ร้านลูกโป่ง เชียงใหม่ เราคือมืออาชีพ และผู้เชี่ยวชาญด้านลูกโป่งตกแต่ง ที่ช่วยเติมเต็มทุกช่วงเวลาสำคัญของคุณให้พิเศษยิ่งขึ้น ด้วยบริการที่หลากหลาย</p>
      <div class="home-services-grid">
        {homeServices.map(s => (
          <div class="home-service-card">
            <div class="home-service-icon">{s.icon}</div>
            <h5 class="home-service-title">{s.title}</h5>
            <p class="home-service-desc">{s.description}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:30px;">
        <a href="/บริการ/" class="btn">ดูบริการเพิ่มเติม</a>
      </div>
    </div>
  </section>

  <!-- Pinky + Strengths -->
  <section class="section-padding">
    <div class="container" style="max-width:900px;">
      <h2 class="section-title">จุดเด่นของเรา</h2>
      <p class="section-subtitle">เรามีบริการจัดส่งลูกโป่งให้ถึงที่ โดยมีรถ "Pinky" เจ้าแรกและเจ้าเดียวในเชียงใหม่</p>
      <div style="max-width:600px; margin:0 auto;">
        <img src={pinkyImage} alt="Pinky car" style="border-radius:var(--radius); box-shadow:var(--shadow-md); width:100%;" />
      </div>
      {pinkyDesc && <p style="margin-top:24px; max-width:700px; margin-inline:auto; line-height:1.8;">{pinkyDesc}</p>}
      <div class="strengths-content" set:html={strengthsContent}></div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding" style="background:var(--bg-light);">
    <div class="container" style="max-width:800px;">
      <h2 class="section-title">คำถามที่พบบ่อย (FAQ)</h2>
      <p class="section-subtitle">คำถามที่ลูกค้ามักสอบถาม</p>
      <div class="faq-list">
        {faq.map((item, i) => (
          <div class="faq-item">
            <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
              <span>{item.question}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p set:html={item.answer}></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding" style="background:var(--bg-light); text-align:center;">
    <div class="container" style="max-width:800px;">
      <h3 style="font-size:1.5rem; margin-bottom:12px;">มีคำถาม หรืออยากปรึกษาออกแบบลูกโป่ง</h3>
      <h4 style="font-size:1rem; font-weight:400; line-height:1.8; color:#666; margin-bottom:24px;">ส่งรูปงาน หรือแนวคิดมาได้เลย เราจะช่วยออกแบบให้สวยที่สุด อุ้มตอบเองทุกข้อความเลย</h4>
      <a href="https://line.me/R/ti/p/@partyvilla" target="_blank" class="btn">พูดคุยกับเรา</a>
    </div>
  </section>

  <!-- Taglines -->
  <section class="section-padding" style="text-align:center;">
    <div class="container" style="max-width:800px;">
      <p style="font-weight:500; margin-bottom:12px;">Party Villa Balloon ร้านลูกโป่งเชียงใหม่ : สร้างความสุขในทุกโอกาส</p>
      <h3 style="font-size:1.2rem; color:var(--primary); margin-bottom:8px;">พร้อมสร้างความประทับใจให้งานคุณแล้ววันนี้</h3>
      <h3 style="font-size:1.2rem; color:var(--primary); margin-bottom:8px;">เติมเต็มสีสัน...สร้างสรรค์ทุกความทรงจำ</h3>
      <h3 style="font-size:1.2rem; color:var(--primary);">&ldquo;ทำด้วยใจ อะไรก็ดี&rdquo;</h3>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
  }
  .owner-name {
    font-size: 1.1rem;
    margin-bottom: 8px;
    display: inline-block;
    background: rgba(251, 60, 139, 0.15);
    color: var(--primary);
    padding: 6px 18px;
    border-radius: 50px;
    font-weight: 700;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  .home-services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 30px;
  }
  .home-service-card {
    background: rgba(237, 172, 36, 0.04);
    border-radius: 15px;
    padding: 30px 20px;
    text-align: center;
    transition: background 0.3s;
  }
  .home-service-card:hover {
    background: rgba(237, 172, 36, 0.08);
  }
  .home-service-icon {
    font-size: 2.2rem;
    margin-bottom: 12px;
  }
  .home-service-title {
    font-size: 1rem;
    color: #000;
    margin-bottom: 8px;
  }
  .home-service-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #666;
  }
  .strengths-content {
    line-height: 2;
    font-size: 1.05rem;
    margin-top: 30px;
  }
  .strengths-content :global(ol),
  .strengths-content :global(ul) {
    padding-left: 24px;
    margin: 12px 0;
  }
  .strengths-content :global(li) {
    margin-bottom: 8px;
  }
  .strengths-content :global(strong) {
    color: var(--primary);
  }

  .faq-list {
    margin-top: 24px;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    padding: 16px 20px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    color: var(--text-color);
  }
  .faq-icon {
    font-size: 1.4rem;
    color: var(--primary);
    transition: transform 0.3s;
    flex-shrink: 0;
    margin-left: 12px;
  }
  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    padding: 0 20px;
  }
  .faq-item.open .faq-answer {
    max-height: 500px;
    padding: 0 20px 16px;
  }
  .faq-answer p {
    line-height: 1.8;
    color: #555;
  }
  @media (max-width: 768px) {
    .home-services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
