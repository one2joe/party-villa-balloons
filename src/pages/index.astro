---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import faq from '../data/faq.json';
import homeContent from '../data/home-content.json';

const galleryImages = homeContent.galleryImages || [];
const tiktokEmbeds = homeContent.tiktokEmbeds || [];
const heroBg = homeContent.hero?.background || '/images/hero-bg.jpg';
const heroTitle = homeContent.hero?.title || 'Party Villa Balloons';
const heroSubtitle = homeContent.hero?.subtitle || 'บริการจัดลูกโป่งครบวงจรในเชียงใหม่';
const ownerTagline = homeContent.hero?.ownerTagline || '';
const pinkyImage = homeContent.pinky?.image || '/images/pinky-car.jpg';
const pinkyDesc = homeContent.pinky?.description || 'รถ Pinky สุดคิ้วท์บริการถึงที่ พร้อมลูกโป่งสวยๆ ส่งตรงถึงงานคุณ';
const intro = homeContent.intro || '';
const siteUrl = 'https://party-villa-balloons.pages.dev';
const shareText = 'Party%20Villa%20Balloons';
---

<Layout title="Party Villa Balloons | รับจัดลูกโป่งเชียงใหม่ ครบวงจร">
  <Header currentPath={Astro.url.pathname} />

  <!-- Hero -->
  <section class="hero-parallax" style={`background-image: url('${heroBg}');`}>
    <div class="hero-content">
      {ownerTagline && <p class="owner-name">{ownerTagline}</p>}
      <h1>{heroTitle}</h1>
      <p>{heroSubtitle}</p>
      <div class="hero-actions">
        <a href="/portfolio" class="btn btn-outline">ดูผลงานของเรา</a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=${siteUrl}" target="_blank" class="btn" style="background:#1877F2;">แชร์ Facebook</a>
      </div>
    </div>
  </section>

  <!-- Welcome + Social Share -->
  <section class="section-padding" style="text-align:center;">
    <div class="container">
      <p style="font-size:1.2rem; max-width:800px; margin:0 auto; line-height:2;">{intro}</p>
      <div class="social-share-bar">
        <span class="share-label">แชร์ให้เพื่อน:</span>
        <a href="https://www.facebook.com/sharer/sharer.php?u=${siteUrl}" target="_blank" class="share-btn" style="background:#1877F2;" aria-label="Facebook">FB</a>
        <a href="https://line.me/R/msg/text/?${shareText}%20${siteUrl}" target="_blank" class="share-btn" style="background:#00B900;" aria-label="LINE">LINE</a>
        <a href="https://twitter.com/intent/tweet?text=${shareText}&url=${siteUrl}" target="_blank" class="share-btn" style="background:#000;" aria-label="X (Twitter)">X</a>
        <a href="https://api.whatsapp.com/send?text=${shareText}%20${siteUrl}" target="_blank" class="share-btn" style="background:#25D366;" aria-label="WhatsApp">WA</a>
        <a href="https://pinterest.com/pin/create/button/?url=${siteUrl}&description=${shareText}" target="_blank" class="share-btn" style="background:#E60023;" aria-label="Pinterest">PIN</a>
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=${siteUrl}" target="_blank" class="share-btn" style="background:#0A66C2;" aria-label="LinkedIn">IN</a>
        <a href="mailto:?subject=Party%20Villa%20Balloons&body=${siteUrl}" target="_blank" class="share-btn" style="background:#666;" aria-label="Email">@</a>
      </div>
    </div>
  </section>

  <!-- Gallery Carousel -->
  <section class="section-padding" style="background:var(--bg-light);">
    <div class="container">
      <h2 class="section-title">ผลงานของเรา</h2>
      <p class="section-subtitle">ภาพตัวอย่างการจัดลูกโป่งในโอกาสต่างๆ</p>
      <div class="swiper gallerySwiper">
        <div class="swiper-wrapper">
          {galleryImages.map(img => (
            <div class="swiper-slide">
              <div class="slide-img-wrap">
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      </div>
    </div>
  </section>

  <!-- Pinky -->
  <section class="section-padding" style="text-align:center;">
    <div class="container">
      <h2 class="section-title">จุดเด่นของเรา</h2>
      <p class="section-subtitle">น้องพิ้งกี้ รถบริการลูกโป่งเชียงใหม่</p>
      <div style="max-width:600px; margin:0 auto;">
        <img src={pinkyImage} alt="Pinky car" style="border-radius:var(--radius); box-shadow:var(--shadow-md); width:100%;" />
      </div>
      {pinkyDesc && <p style="margin-top:24px; max-width:700px; margin-inline:auto;">{pinkyDesc}</p>}
    </div>
  </section>

  <!-- TikTok -->
  <section class="section-padding" style="background:var(--bg-light);">
    <div class="container">
      <h2 class="section-title">ติดตามเราบน TikTok</h2>
      <p class="section-subtitle">@partyvillaballoon</p>
      <div class="tiktok-embed-grid">
        {tiktokEmbeds.map(t => (
          <blockquote class="tiktok-embed" cite={t.url} data-video-id={t.videoId}>
            <section></section>
          </blockquote>
        ))}
      </div>
      <div style="text-align:center; margin-top:30px;">
        <a href="https://www.tiktok.com/@partyvillaballoon" target="_blank" class="btn">ดูเพิ่มเติมบน TikTok</a>
      </div>
    </div>
    <script async src="https://www.tiktok.com/embed.js"></script>
  </section>

  <!-- FAQ -->
  <section class="section-padding">
    <div class="container" style="max-width:800px;">
      <h2 class="section-title">คำถามที่พบบ่อย</h2>
      <p class="section-subtitle">FAQ</p>
      <div class="faq-list">
        {faq.map((item, i) => (
          <div class="faq-item">
            <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
              <span>{item.question}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p set:html={item.answer}></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding" style="background:var(--primary); color:#fff; text-align:center;">
    <div class="container">
      <h2 style="font-size:1.8rem; margin-bottom:16px;">มีคำถามเกี่ยวกับการจัดลูกโป่ง?</h2>
      <p style="font-size:1.1rem; margin-bottom:24px;">อุ้มตอบเองทุกข้อความ</p>
      <a href="https://line.me/R/ti/p/@partyvilla" target="_blank" class="btn" style="background:#fff; color:var(--primary);">พูดคุยกับเรา</a>
    </div>
  </section>

  <Footer />
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
  .owner-name {
    font-size: 1.1rem;
    margin-bottom: 8px;
    display: inline-block;
    background: rgba(251, 60, 139, 0.15);
    color: var(--primary);
    padding: 6px 18px;
    border-radius: 50px;
    font-weight: 700;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  .social-share-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  .share-label {
    font-weight: 700;
    color: #666;
    margin-right: 4px;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    transition: transform 0.2s, opacity 0.2s;
  }
  .share-btn:hover {
    transform: scale(1.1);
    opacity: 0.9;
  }
  .swiper {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding-bottom: 50px;
  }
  .slide-img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
  }
  .slide-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .swiper-pagination-bullet-active {
    background: var(--primary) !important;
  }
  .swiper-button-next,
  .swiper-button-prev {
    color: var(--primary) !important;
  }
  .tiktok-embed-grid {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .tiktok-embed-grid .tiktok-embed {
    min-width: 325px;
    max-width: 400px;
    flex: 1;
  }
  @media (max-width: 768px) {
    .tiktok-embed-grid {
      flex-direction: column;
      align-items: center;
    }
    .tiktok-embed-grid .tiktok-embed {
      min-width: unset;
      width: 100%;
      max-width: 400px;
    }
    .social-share-bar {
      gap: 6px;
    }
    .share-btn {
      width: 38px;
      height: 38px;
      font-size: 0.7rem;
    }
  }
</style>

<script>
  import Swiper from 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs';

  new Swiper('.gallerySwiper', {
    slidesPerView: 1,
    spaceBetween: 16,
    loop: true,
    autoplay: {
      delay: 4000,
      disableOnInteraction: false,
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    breakpoints: {
      640: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
