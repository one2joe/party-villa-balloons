---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import services from '../../data/services.json';
import servicesContent from '../../data/services-content.json';

const heroBg = servicesContent.hero?.background || '/images/services-hero.jpg';
const pricingUrl = servicesContent?.pricingUrl || '';
const pageTitle = 'บริการ - Party Villa';
const pageDesc = 'ออกแบบไม่ซ้ำใคร ใช้ลูกโป่งเกรดพรีเมียม ผสานเทคนิคการจัดวางสมัยใหม่';
---

<Layout title={pageTitle} description={pageDesc}>
  <Header currentPath={Astro.url.pathname} />
  <div style="display:none" aria-hidden="true">
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="Party Villa" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
    <img src="https://xn--12cmal7ftbft4d7etb1fxav2ej.com/wp-content/uploads/2025/03/Logo-Party-Villa.png" alt="" />
  </div>

  <section class="hero-parallax" style="background-color: rgb(251, 60, 139);">
    <div class="hero-content">
      <h3 style="font-size:1.5rem;">{'บริการของเรา'}</h3>
      <p>ออกแบบไม่ซ้ำใคร ใช้ลูกโป่งเกรดพรีเมียม ผสานเทคนิคการจัดวางสมัยใหม่</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <h2 class="section-title">{'บริการหลัก'}</h2>
      <div class="services-grid">
        {services.map(s => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h4 class="service-title">{s.title}</h4>
            <p class="service-desc">{s.description}</p>
            <ul class="service-features">
              {s.features.map(f => (
                <li>{f}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      {pricingUrl && (
        <div style="text-align:center; margin-top:40px;">
          <a href={pricingUrl} target="_blank" class="btn">ดูราคาแพ็กเกจ</a>
        </div>
      )}
    </div>
  </section>

  <section class="section-padding" style="background:var(--bg-light);">
    <div class="container" style="max-width:900px;">
      <h2 class="section-title">เราแก้ปัญหาอะไรให้ลูกค้า</h2>
      <p class="section-subtitle">เราช่วยลูกค้าทุกขั้นตอน ตั้งแต่เริ่มต้นจนถึงวันงาน</p>
      <div class="problems-grid">
        {servicesContent.problems.map(p => (
          <div class="problem-card">
            <div class="problem-step">{p.step}</div>
            <p class="problem-title">{p.title}</p>
            <p class="problem-solution">{p.solution}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width:1000px;">
      <h2 class="section-title">พร้อมบริการจัดแต่งลูกโป่งตามธีมงานต่าง ๆ</h2>
      <p class="section-subtitle">ทุกชิ้นงานออกแบบด้วยความพิถีพิถัน ตอบโจทย์ตามงบประมาณ และสามารถปรับแต่งให้เข้ากับธีมของคุณได้</p>
      <div class="themes-grid">
        {servicesContent.themes.map(theme => (
          <div class="theme-card">
            <div class="theme-icon">{theme.icon}</div>
            <h3 class="theme-title">{theme.title}</h3>
            <p class="theme-subtitle">{theme.subtitle}</p>
            <p class="theme-desc">{theme.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding" style="background:var(--bg-light); text-align:center;">
    <div class="container" style="max-width:800px;">
      <p style="font-size:1.3rem; color:var(--primary); margin-bottom:20px; font-weight:500;">{servicesContent.tagline}</p>
      {servicesContent.taglines.map(t => (
        <h3 style="font-size:1.15rem; line-height:2; font-weight:500;">{t}</h3>
      ))}
    </div>
  </section>

  <div style="display:none" aria-hidden="true">
    <a class="button" href="https://www.canva.com/design/DAGMzYyp9Ak/Xku-Mb9-LAg9vaO_O1XYqA/edit"><i class="icon-angle-right"></i>อัตราค่าบริการลูกโป่งแต่ละแบบ</a>
    <button>Previous</button>
    <button>Next</button>
  </div>

  <Footer />
</Layout>
<script>
  if (window.innerWidth < 768) {
    var h = document.querySelector('header');
    if (h) {
      var menuBtn = h.querySelector('a[aria-label="เมนู"]');
      var searchBtn = h.querySelector('a[aria-label="ค้นหา"]');
      if (menuBtn) menuBtn.remove();
      if (searchBtn) searchBtn.remove();
    }
  }
</script>

<style>
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .service-card { background: rgba(237, 172, 36, 0.04); border-radius: 15px; padding: 40px 30px; text-align: center; transition: background 0.3s; }
  .service-card:hover { background: rgba(237, 172, 36, 0.08); }
  .service-icon { font-size: 3rem; margin-bottom: 16px; }
  .service-title { font-size: 1.2rem; color: var(--text-color); margin-bottom: 12px; }
  .service-desc { color: #666; line-height: 1.8; margin-bottom: 16px; font-size: 0.95rem; }
  .service-features { text-align: left; list-style: disc; padding-left: 20px; line-height: 2; color: #555; font-size: 0.9rem; }
  .problems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 30px; }
  .problem-card { background: rgba(237, 172, 36, 0.04); border-radius: 15px; padding: 30px; text-align: center; }
  .problem-step { display: inline-block; background: var(--primary); color: #fff; padding: 4px 14px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; margin-bottom: 12px; }
  .problem-title { font-size: 1rem; margin-bottom: 10px; color: var(--text-color); }
  .problem-solution { font-size: 0.9rem; line-height: 1.7; color: #666; }
  .themes-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 30px; }
  .theme-card { background: rgba(237, 172, 36, 0.04); border-radius: 15px; padding: 30px; text-align: center; transition: background 0.3s; }
  .theme-card:hover { background: rgba(237, 172, 36, 0.08); }
  .theme-icon { font-size: 2.5rem; margin-bottom: 12px; }
  .theme-title { font-size: 1rem; color: var(--text-color); margin-bottom: 4px; }
  .theme-subtitle { font-size: 0.85rem; color: #999; margin-bottom: 10px; font-style: italic; }
  .theme-desc { font-size: 0.9rem; line-height: 1.7; color: #666; }
  @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } .problems-grid { grid-template-columns: 1fr; } .themes-grid { grid-template-columns: 1fr; } }
</style>
