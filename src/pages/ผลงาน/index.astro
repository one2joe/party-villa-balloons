  <section class="hero-parallax" style="background-color: rgb(251, 60, 139);">
    <div class="hero-content">
      <h3 style="font-size:1.5rem;">{'ผลงาน'}</h3>
      <p>{'รวมผลงานการจัดลูกโป่งทุกรูปแบบ'}</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width:900px; text-align:center; margin-bottom:0;">
      <h2 style="font-size:1.3rem; color:var(--text-color); line-height:1.6;">เราเข้าใจดีว่าทุกงานมีเอกลักษณ์เฉพาะตัว… จึงพร้อมออกแบบลูกโป่งที่ตอบโจทย์ที่สุด</h2>
    </div>
  </section>

  <section class="section-padding" style="padding-top:0;">
    <div class="container gallery-layout">
      <aside class="gallery-sidebar">
        <p style="margin-bottom:16px; color:var(--primary); font-weight:700;">{'หมวดหมู่'}</p>
        <div>
          <ul style="display:flex; flex-direction:column; gap:4px;">
            {gallery.map((cat, i) => (
              <li><a href={`#cat-${i}`} class="sidebar-link">{cat.category}</a></li>
            ))}
          </ul>
        </div>
        {googlePhotosUrl && (
          <div class="sidebar-cta">
            <p style="margin-bottom:12px; font-weight:500;">{'ดูผลงานทั้งหมด'}</p>
            <a href={googlePhotosUrl} target="_blank" class="btn" style="font-size:0.9rem; padding:10px 20px;">Google Photos</a>
          </div>
        )}
        <div class="sidebar-cta" style="margin-top:12px;">
          <p style="margin-bottom:12px; font-weight:500;">{'สนใจจัดลูกโป่ง?'}</p>
          <a href="/ติดต่อเรา/" class="btn" style="font-size:0.9rem; padding:10px 20px;">{'ติดต่อเรา'}</a>
        </div>
      </aside>

      <div class="gallery-main">
        {gallery.filter(cat => cat.images?.length > 0).map((cat, i) => (
          <div id={`cat-${i}`} class="gallery-section">
            <h3 class="gallery-section-title">{cat.category}</h3>
            <div class="gallery-grid">
              {cat.images.map(img => (
                <a href={img.src} target="_blank" rel="noopener noreferrer" class="gallery-item">
                  <div style="width:100%;height:100%;background:url({img.src}) center/cover no-repeat;transition:transform 0.3s;" class="gallery-img" role="img" aria-label={img.alt}></div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding" style="background:var(--bg-light); text-align:center;">
    <div class="container" style="max-width:800px;">
      <p style="font-size:1.3rem; color:var(--primary); margin-bottom:20px; font-weight:500;">Party Villa Balloon ร้านลูกโป่งเชียงใหม่ : สร้างความสุขในทุกโอกาส</p>
      <h3 style="font-size:1.15rem; line-height:2; font-weight:500;">พร้อมสร้างความประทับใจให้งานคุณแล้ววันนี้</h3>
      <h3 style="font-size:1.15rem; line-height:2; font-weight:500;">เติมเต็มสีสัน...สร้างสรรค์ทุกความทรงจำ</h3>
      <h3 style="font-size:1.15rem; line-height:2; font-weight:500;">&quot;ทำด้วยใจ อะไรก็ดี&quot;</h3>
    </div>
  </section>

  <div style="display:none" aria-hidden="true">
    <a class="button" href="https://photos.app.goo.gl/UWgzv4fY73qKjBuW6"><i class="icon-google-plus"></i>ดูผลงานของเราเพิ่มเติมได้ที่</a>
  </div>

  <Footer />
</Layout>

<style>
  .gallery-layout { display: flex; gap: 30px; align-items: flex-start; }
  .gallery-sidebar { width: 260px; flex-shrink: 0; position: sticky; top: 100px; background: #fff; border: 1px solid var(--border-color); border-radius: var(--radius); padding: 24px; }
  .sidebar-link { display: block; padding: 10px 14px; border-radius: 6px; font-size: 0.95rem; transition: background 0.3s, color 0.3s; }
  .sidebar-link:hover { background: var(--bg-light); color: var(--primary); }
  .sidebar-cta { margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border-color); text-align: center; }
  .gallery-main { flex: 1; min-width: 0; }
  .gallery-section { margin-bottom: 50px; }
  .gallery-section-title { font-size: 1.5rem; margin-bottom: 20px; padding-bottom: 8px; border-bottom: 2px solid var(--primary); }
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .gallery-item { border-radius: 6px; overflow: hidden; aspect-ratio: 1; display: block; cursor: pointer; }
  .gallery-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .gallery-img:hover { transform: scale(1.08); }
  @media (max-width: 768px) { .gallery-layout { flex-direction: column; } .gallery-sidebar { width: 100%; position: static; } .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

