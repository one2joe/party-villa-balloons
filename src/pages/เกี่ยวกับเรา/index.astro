---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import aboutContent from '../../data/about-content.json';

const heroBg = aboutContent.hero?.background || '/images/about-hero.jpg';
const ownerImages = aboutContent.images || [];
const sections = aboutContent.sections || [];
const storySection = sections[1] || null;
const strengthsSection = sections[2] || null;
const missionSection = sections[4] || null;
const tagline = aboutContent.sections?.[3] || null;
const ownerPhoto = ownerImages.find(i => i.alt.includes('อุ้ม')) || ownerImages[1] || null;
const teamImages = ownerImages.filter(i => i.alt.includes('ทีมงาน')) || [];
const logoImage = ownerImages.find(i => i.alt.includes('Logo')) || null;
const heroPhoto = ownerImages.find(i => i.src.includes('คุณอุ้ม-ลูกโป่งเชียงใหม่-5')) || null;

const strengthsContent = strengthsSection?.content?.replace('จุดเด่นของเรา\n', '') || '';
const storyContent = storySection?.content?.replace('เกี่ยวกับเรา\n', '') || '';
const missionContent = missionSection?.content?.replace(missionSection?.title || '', '')?.trim() || '';
const pageTitle = 'เกี่ยวกับเรา - Party Villa';
const pageDesc = 'เส้นทางของ Party Villa Balloon ลูกโป่งเชียงใหม่: จากจุดเริ่มต้นสู่ร้านลูกโป่งอันดับหนึ่งในเชียงใหม่ Party Villa Balloon';
---

<Layout title={pageTitle} description={pageDesc}>
  <Header currentPath={Astro.url.pathname} />

  <section class="hero-parallax" style={`background-image: url('${heroBg}');`}>
    <div class="hero-content">
      <h1>{'เกี่ยวกับเรา'}</h1>
      <p>{'รู้จักกับ Party Villa Balloons'}</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container" style="max-width:1000px;">
      <div class="story-grid">
        <div class="story-images">
          {ownerPhoto && (
            <img src={ownerPhoto.src} alt={ownerPhoto.alt} class="story-main-img" />
          )}
          {heroPhoto && (
            <img src={heroPhoto.src} alt={heroPhoto.alt} class="story-secondary-img" />
          )}
          {logoImage && (
            <img src={logoImage.src} alt={logoImage.alt} class="story-logo" />
          )}
        </div>
        <div class="story-text">
          <h3 class="section-subtitle" style="color:var(--primary); font-weight:400;">{'จากความชอบสู่ความเชี่ยวชาญ'}</h3>
          <h2 class="story-heading">{'เส้นทางของ Party Villa Balloon ลูกโป่งเชียงใหม่'}</h2>
          <div class="story-body" set:html={storyContent}></div>
        </div>
      </div>
    </div>
  </section>

  {strengthsSection && (
    <section class="section-padding" style="background:var(--bg-light);">
      <div class="container" style="max-width:900px;">
        <div class="strengths-header">
          <h2 class="section-title">{'จุดเด่นของเรา'}</h2>
          <p class="section-subtitle">{'บริษัท ปาร์ตี้ วิลล่า บอลลูน จำกัด เป็นผู้เชี่ยวชาญด้านลูกโป่งตกแต่งทุกประเภท ด้วยประสบการณ์มากกว่า 8 ปี'}</p>
        </div>
        <div class="strengths-content" set:html={strengthsContent}></div>
      </div>
    </section>
  )}

  {tagline && (
    <section class="section-padding" style="text-align:center;">
      <div class="container" style="max-width:800px;">
        <blockquote class="tagline-quote">
          "{tagline.title}"
        </blockquote>
      </div>
    </section>
  )}

  {teamImages.length > 0 && (
    <section class="section-padding" style="background:var(--bg-light);">
      <div class="container" style="max-width:1000px;">
        <h2 class="section-title">{'ทีมงานของเรา'}</h2>
        <div class="team-grid">
          {teamImages.map(img => (
            <div class="team-card">
              <img src={img.src} alt={img.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {missionSection && (
    <section class="section-padding">
      <div class="container" style="max-width:900px;">
        <div class="mission-box">
          <h3 class="mission-title">{missionSection.title}</h3>
          <div class="mission-body" set:html={missionContent}></div>
        </div>
      </div>
    </section>
  )}

  <Footer />
</Layout>

<style>
  .story-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 50px; align-items: start; }
  .story-images { display: flex; flex-direction: column; gap: 16px; }
  .story-main-img { border-radius: var(--radius); box-shadow: var(--shadow-md); width: 100%; }
  .story-secondary-img { border-radius: var(--radius); box-shadow: var(--shadow-sm); width: 100%; }
  .story-logo { max-width: 180px; margin: 0 auto; display: block; }
  .story-heading { font-size: 1.4rem; margin-bottom: 16px; color: var(--text-color); }
  .story-body { line-height: 2; font-size: 1rem; }
  .story-body :global(p) { margin-bottom: 16px; }
  .strengths-header { text-align: center; margin-bottom: 30px; }
  .strengths-content { line-height: 2; font-size: 1.05rem; }
  .strengths-content :global(ol), .strengths-content :global(ul) { padding-left: 24px; margin: 12px 0; }
  .strengths-content :global(li) { margin-bottom: 8px; }
  .strengths-content :global(strong) { color: var(--primary); }
  .tagline-quote { font-size: 1.3rem; color: var(--primary); font-weight: 700; line-height: 1.6; }
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .team-card { border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); }
  .team-card img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 1; }
  .mission-box { background: #fff; border: 1px solid var(--border-color); border-radius: var(--radius); padding: 40px; text-align: center; }
  .mission-title { color: var(--primary); margin-bottom: 16px; font-size: 1.3rem; }
  .mission-body { line-height: 2; max-width: 700px; margin: 0 auto; }
  .mission-body :global(a) { color: var(--primary); font-weight: 500; }
  @media (max-width: 768px) { .story-grid { grid-template-columns: 1fr; } .team-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

