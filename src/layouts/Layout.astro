---
import '../styles/global.css';
import siteSettings from '../data/site-settings.json';
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'หน้าแรก - Party Villa', description = '🎈✨ ยินดีต้อนรับสู่ "ปาร์ตี้ วิลล่า บอลลูน" 🎉🎊 คุณกำลังมองหาการตกแต่งงานปาร์ตี้ที่สวยงามและน่าประทับใจอยู่ใช่ไหม? มาหาเราที่ "ปาร์ตี้ วิลล่า บอลลูน"' } = Astro.props;
const logo = siteSettings?.logo || '/images/logo.png';
const siteUrl = siteSettings?.url || '';
---

